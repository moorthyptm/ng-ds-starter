{
  "name": "ng-ds-starter",
  "version": "0.1.0",
  "description": "An open-source design system starter kit built with Angular 22 signals, Storybook, strict TypeScript, ESLint, Prettier, Husky, and Commitlint.",
  "author": {
    "name": "moorthyptm",
    "url": "https://github.com/moorthyptm"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moorthyptm/ng-ds-starter.git"
  },
  "bugs": {
    "url": "https://github.com/moorthyptm/ng-ds-starter/issues"
  },
  "homepage": "https://github.com/moorthyptm/ng-ds-starter#readme",
  "keywords": [
    "angular",
    "angular-cli",
    "angular-signals",
    "signals",
    "storybook",
    "design-system",
    "starter-kit",
    "boilerplate",
    "typescript",
    "eslint",
    "prettier",
    "husky",
    "commitlint"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "lint-staged": "lint-staged"
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "22.0.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1"
  },
  "lint-staged": {
    "*.{ts,html,css,scss}": [
      "prettier --write"
    ],
    "*.{ts,html}": [
      "eslint"
    ]
  }
}
